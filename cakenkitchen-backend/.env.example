# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development

# DATABASE CONFIGURATION (XAMPP or Cloud MySQL host parameters)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cakenk

# AUTHENTICATION SECURITY
# Generate a strong, unique secret key for JWT signatures
JWT_SECRET=generate_strong_random_secret_string

# CROSS-ORIGIN RESOURCE SHARING (CORS)
# Point this to your front-end domain URL (e.g. Vercel deployment URL)
FRONTEND_URL=http://localhost:5173
